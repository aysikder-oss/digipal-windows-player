{
  "name": "digipal-windows-player",
  "version": "2.0.0",
  "description": "Digipal Digital Signage Player for Windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "author": "Digipal",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {},
  "build": {
    "appId": "com.digipal.player",
    "productName": "Digipal Player",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Digipal Player",
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "DigipalPlayer-${version}-portable.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*"
    ]
  }
}
